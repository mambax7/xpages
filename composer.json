{
    "name": "xoops/xpages",
    "description": "xPages — Static Pages Module for XOOPS 2.7.0",
    "type": "xoops-module",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Eren Yumak",
            "homepage": "https://aymak.net"
        }
    ],
    "require": {
        "php": ">=8.2 <8.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.0",
        "vimeo/psalm": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "XoopsModules\\Xpages\\": "class/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XoopsModules\\Xpages\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "psalm": "psalm"
    }
}
